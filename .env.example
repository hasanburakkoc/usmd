# Public site URL (canonical links, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://usmdinternational.com

# --- Firestore (treatment catalog on home + /treatments only) ---
GOOGLE_CLOUD_PROJECT=usmd-494513
FIRESTORE_DATABASE_ID=(default)
FIREBASE_SERVICE_ACCOUNT_PATH=C:\Users\YOU\Downloads\your-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Lead form → Resend (https://resend.com/api-keys) ---
RESEND_API_KEY=re_xxxxxxxx
# Optional. If unset, uses Resend's built-in test sender:
#   USMD <onboarding@resend.dev>
# RESEND_FROM=USMD <you@your-verified-domain.com>
# Inbox(es) that receive each submission (comma-separated). Use an address you read.
RESEND_TO=you@example.com
