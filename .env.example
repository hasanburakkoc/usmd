# Server-side Firebase Admin (Firestore)
GOOGLE_CLOUD_PROJECT=usmd-494513

# First Firestore DB is usually (default); set if yours differs.
FIRESTORE_DATABASE_ID=(default)

# Easiest on Windows: path to the JSON file you downloaded (no copy-paste of secret):
FIREBASE_SERVICE_ACCOUNT_PATH=C:\Users\YOU\Downloads\your-service-account.json

# Optional instead of PATH: paste the whole JSON on one line (advanced)
# FIREBASE_SERVICE_ACCOUNT_JSON=
